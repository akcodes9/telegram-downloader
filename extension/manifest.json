{
  "manifest_version": 3,
  "name": "Telegram Video Downloader (MVP)",
  "version": "1.0",
  "description": "Download videos from Telegram Web",
  "permissions": ["downloads", "storage", "scripting", "activeTab"],
  "host_permissions": ["https://web.telegram.org/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.telegram.org/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
